import React, { useState } from "react";
import LegalDisclaimer from "../LegalDisclaimer.jsx";

/**
 * A1 — Procedural Wear Shader (Blender 5.1 / Cycles)
 * ---------------------------------------------------
 * Self-contained LMS lesson component. No external dependencies:
 * all screenshots, renders and node diagrams are embedded as data URLs.
 * Every value shown was captured from the actual working .blend file.
 *
 * Usage:  import ProceduralWearLesson from "./ProceduralWearLesson";
 *         <ProceduralWearLesson />
 */

const IMG = {
"before": "data:image/jpeg;base64,",
"patina": "data:image/jpeg;base64,",
"pits": "data:image/jpeg;base64,",
"chips": "data:image/jpeg;base64,",
"edge": "data:image/jpeg;base64,",
"edgeBroad": "data:image/jpeg;base64,",
"wear": "data:image/jpeg;base64,",
"rust": "data:image/jpeg;base64,",
"final": "data:image/jpeg;base64,",
"treeFull": "data:image/svg+xml;base64,",
