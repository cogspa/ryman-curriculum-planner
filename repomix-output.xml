function DropIndicator({ onDrop, active }) {
  const [dragOver, setDragOver] = useState(false);

  return (
    <div
      className={`drop-indicator ${active ? 'active' : ''} ${dragOver ? 'drag-over' : ''}`}
      onDragOver={(e) => {
        e.preventDefault();
        setDragOver(true);
      }}
      onDragEnter={(e) => {
        e.preventDefault();
        setDragOver(true);
      }}
      onDragLeave={() => setDragOver(false)}
      onDrop={(e) => {
        e.preventDefault();
        setDragOver(false);
        onDrop();
      }}
    />
  );
}

function EmptyDropZone({ onDrop, active }) {
