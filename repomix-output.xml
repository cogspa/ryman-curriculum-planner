              src="/symmetry_dropdown.png" 
              alt="Photoshop Symmetry Dropdown Menu" 
              style={{ 
                width: '100%', 
                height: 'auto', 
                display: 'block', 
                border: '1.5px solid #1a1a1a', 
                borderRadius: '4px',
